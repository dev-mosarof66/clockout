# RevenueCat public Android SDK key (starts with "goog_").
# Get it from app.revenuecat.com → your project → API keys.
# Copy this file to .env.local and fill it in. Without it, the app runs but
# purchases are disabled (paywall falls back to the local trial flow).
EXPO_PUBLIC_RC_ANDROID_KEY=""

# PostHog project API key (starts with "phc_") for anonymous product analytics.
# Get it from posthog.com → Project settings → API keys. Without it, analytics
# is fully disabled (no events are sent). Host defaults to US cloud below.
EXPO_PUBLIC_POSTHOG_KEY=""
EXPO_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
